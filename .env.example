# MatchMesh — copy to .env and fill in. Never commit the real .env.
NETWORK=eip155:1439
# NOTE: the "official" k8s.testnet.json-rpc.injective.network endpoint does NOT
# reliably serve eth_getTransactionByHash/Receipt (confirmed 2026-07-11 — a real
# tx was mined, nonce advanced, but that RPC returned null for its own hash
# forever). Use the archival gateway instead, which resolves it correctly.
RPC_URL=https://testnet.evm.archival.chain.virtual.json-rpc.injective.network
USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
PORT=4021

TREASURY_PRIVATE_KEY=0x...
TREASURY_ADDRESS=0x...
INTERNAL_SECRET=generate-a-random-hex-string

STATCASTER_PRIVATE_KEY=0x...
STATCASTER_ADDRESS=0x...

SCOUT_PRIVATE_KEY=0x...
SCOUT_ADDRESS=0x...

TIPPER_PRIVATE_KEY=0x...
TIPPER_ADDRESS=0x...

MCP_OPERATOR_PRIVATE_KEY=0x...
MCP_OPERATOR_ADDRESS=0x...

# Optional: daily USD cap on the MCP operator wallet's auto-pay (the /mcp endpoint
# is public and pays on the caller's behalf — this bounds worst-case drain). Defaults to 2.
MCP_DAILY_BUDGET_USD=2

# Only needed to run scripts/cctp-bridge.js (a one-off funding operation, not
# part of the live server). Same address works on Sepolia and Injective, so this
# can just be TREASURY_PRIVATE_KEY again if you don't want a separate key.
SEPOLIA_PRIVATE_KEY=0x...
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
